# ========================
# DEPENDENCIES
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# ENV FILES (VERY IMPORTANT)
# ========================
.env
.env.local
.env.development
.env.test
.env.production

# backend env
backend/.env
backend/.env.*

# frontend env
frontend/.env
frontend/.env.*

# ========================
# BUILD OUTPUTS
# ========================
dist/
build/
out/

frontend/dist/
frontend/build/

backend/dist/
backend/build/

# ========================
# LOGS
# ========================
logs/
*.log

# ========================
# OS FILES
# ========================
.DS_Store
Thumbs.db

# ========================
# IDE / EDITOR
# ========================
.vscode/
.idea/

*.swp
*.swo

# ========================
# UPLOADS (IMPORTANT - don't push user files)
# ========================
backend/uploads/
uploads/
backend/src/uploads/

# but keep folder structure
!backend/uploads/.gitkeep

# ========================
# COVERAGE / TEST
# ========================
coverage/

# ========================
# CACHE
# ========================
.cache/
.parcel-cache/
.eslintcache

# ========================
# DOCKER (if used later)
# ========================
docker-compose.override.yml

# ========================
# SECURITY / KEYS
# ========================
*.pem
*.key

# ========================
# OPTIONAL
# ========================
*.tsbuildinfo